stateDiagram-v2
    [*] --> SKU_GENERATED: SAP: SKU Created
    
    SKU_GENERATED --> ORDER_DRESSED: Apriso: Order Dressed
    ORDER_DRESSED --> ROUTING_GENERATED: Apriso: Routing Generated
    
    ROUTING_GENERATED --> FLEXI_PROPOSED: CP: Flexi WOs Proposed
    FLEXI_PROPOSED --> FIRM_PROPOSED: OC: Firm WOs Proposed
    
    FIRM_PROPOSED --> FIRM_REGISTERED: Apriso: Firm WOs Registered
    FIRM_REGISTERED --> SCHEDULED: CRSCH: Scheduled
    
    SCHEDULED --> EXECUTION_READY: Apriso: Ready for Execution
    EXECUTION_READY --> IN_EXECUTION: Apriso: In Execution
    
    IN_EXECUTION --> OPERATION_FEEDBACK: Apriso: Operation Feedback
    OPERATION_FEEDBACK --> IN_EXECUTION: Continue Execution
    
    IN_EXECUTION --> COMPLETED: Apriso: Completed
    COMPLETED --> FEEDBACK_TO_SAP: SAP: Import WO Results
    FEEDBACK_TO_SAP --> [*]
    
    %% Alternative paths for quality decisions
    IN_EXECUTION --> KKB_HOLD: Quality Issue (KKB)
    KKB_HOLD --> SCRAP_DECISION: Quality Decision
    SCRAP_DECISION --> SCRAPPED: Scrap
    SCRAPPED --> [*]
    
    SCRAP_DECISION --> REUSE_DECISION: Reuse
    REUSE_DECISION --> FIRM_REGISTERED
    
    SCRAP_DECISION --> CONTINUE_DECISION: Continue
    CONTINUE_DECISION --> IN_EXECUTION
    
    SCRAP_DECISION --> REWORK_DECISION: Rework
    REWORK_DECISION --> ROUTING_MODIFIED: Routing Modified
    ROUTING_MODIFIED --> IN_EXECUTION
    
    %% Cancellation path
    FLEXI_PROPOSED --> CANCELLED: Order Cancelled
    FIRM_PROPOSED --> CANCELLED
    CANCELLED --> [*]
    
